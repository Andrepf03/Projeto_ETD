# ====================================================================
# Copia este ficheiro para .env e preenche os valores.
# O .env NUNCA deve ser commitado (ja esta no .gitignore).
# ====================================================================

# --- Spotify Web API (fluxo Client Credentials; sem login de utilizador) ---
# Obtem em https://developer.spotify.com/dashboard (Settings da tua app)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- ReccoBeats (sem chave a data; confirmar host atual na documentacao) ---
RECCOBEATS_BASE_URL=https://api.reccobeats.com/v1

# --- MusicBrainz (sem chave; o contacto vai no User-Agent, exigido pela MB) ---
MUSICBRAINZ_APP_NAME=ProjetoETD
MUSICBRAINZ_APP_VERSION=0.1.0
MUSICBRAINZ_CONTACT=teu-email@exemplo.pt

# --- Last.fm (OPCIONAL, so para a pergunta analitica 5) ---
LASTFM_API_KEY=

# --- Execucao ---
DATA_DIR=./data
LOG_LEVEL=INFO
